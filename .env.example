MEMORY_API_PORT=4000
WORKER_PORT=4010
REDIS_URL=redis://localhost:6380
MEMORY_STATE_BACKEND=file
MEMORY_STATE_REDIS_KEY=chronogram:state:v1
WEAVIATE_HTTP_URL=http://localhost:8080
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=chronogram
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
EMBEDDING_PROVIDER=transformers
EMBEDDING_MODEL=onnx-community/Qwen3-Embedding-0.6B-ONNX
EMBEDDING_DTYPE=q8
EMBEDDING_DIMENSIONS=1024
EMBEDDING_QUERY_INSTRUCTION=Given an agent memory recall query, retrieve relevant memories that answer or contextualize the query
EMBEDDING_CACHE_DIR=./data/models/transformers
RERANKER_MODEL=bge-reranker-base
EXTRACTION_MODEL=qwen2.5:14b
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text
MAX_REQUEST_BYTES=1048576
SHUTDOWN_TIMEOUT_MS=10000
# Optional. When set, all non-health API and worker routes require x-api-key or Bearer auth.
CHRONOGRAM_API_KEY=
CHRONOGRAM_AUTH_MODE=api-key
CHRONOGRAM_JWT_ISSUER=
CHRONOGRAM_JWT_AUDIENCE=
CHRONOGRAM_JWKS_URL=
CHRONOGRAM_JWT_REQUIRED_SCOPES=
TEMPORAL_GRAPH_BACKEND=neo4j-temporal
GRAPHITI_PYTHON_BIN=python3
GRAPHITI_BRIDGE_SCRIPT=./scripts/graphiti_bridge.py
GRAPHITI_GROUP_ID=chronogram-episodic
MEMORY_DATA_DIR=./data
MEMORY_DATA_FILE=./data/chronogram-memory-os.json
